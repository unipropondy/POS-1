{
  "expo": {
    "name": "Smart POS",
    "slug": "pos-1",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/logo.png",
    "scheme": "restaurantapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "backgroundColor": "#F8FAFC"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FF8C00",
        "foregroundImage": "./assets/images/logo.png"
      },
      "package": "com.javi06.pos1",
      "versionCode": 1
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FF8C00",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "5bb6afb3-f13c-4d31-8888-bacd54796371"
      }
    },
    "owner": "javi06"
  }
}
